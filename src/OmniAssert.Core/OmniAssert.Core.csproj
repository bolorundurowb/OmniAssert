<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>OmniAssert</RootNamespace>
    <AssemblyName>OmniAssert.Core</AssemblyName>
    <Description>OmniAssert runtime: Verify API, diffing, and soft assertion scopes.</Description>
    <LangVersion>14</LangVersion>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>OmniAssert</PackageId>
    <Version>1.0.0-alpha.0</Version>
    <Title>Omni Assert</Title>
    <Authors>Winner-Timothy Bolorunduro</Authors>
    <PackageTags>omni, assert, testing, assertion</PackageTags>
    <PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
  </PropertyGroup>

</Project>
