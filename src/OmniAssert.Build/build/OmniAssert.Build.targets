<Project>
  <PropertyGroup>
    <OmniAssertRewriteTaskAssembly Condition="'$(OmniAssertRewriteTaskAssembly)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\$(IntermediateOutputPath)omniassert-load\OmniAssert.Build.dll'))</OmniAssertRewriteTaskAssembly>
    <OmniAssertRewriteTaskLoadDir Condition="'$(OmniAssertRewriteTaskLoadDir)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\$(IntermediateOutputPath)omniassert-load\'))</OmniAssertRewriteTaskLoadDir>
  </PropertyGroup>

  <UsingTask TaskName="OmniAssert.Build.OmniAssertRewriteTask" AssemblyFile="$(OmniAssertRewriteTaskAssembly)" />

  <Target Name="OmniAssertStageTaskAssemblies"
          BeforeTargets="OmniAssertRewrite"
          Condition="'$(OmniAssertRewrite)' != 'false' and '$(DesignTimeBuild)' != 'true' and '$(BuildingProject)' == 'true'">
    <MakeDir Directories="$(OmniAssertRewriteTaskLoadDir)" />
    <ItemGroup>
      <_OmniAssertTaskPayload Include="$(OmniAssertBuildTaskSourceDir)*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_OmniAssertTaskPayload)"
          DestinationFolder="$(OmniAssertRewriteTaskLoadDir)"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="OmniAssertRewrite"
          BeforeTargets="CoreCompile"
          Condition="'$(OmniAssertRewrite)' != 'false' and '$(DesignTimeBuild)' != 'true' and '$(BuildingProject)' == 'true'">
    <OmniAssertRewriteTask
        Compile="@(Compile)"
        ReferencePath="@(ReferencePathWithRefAssemblies)"
        IntermediateOutputPath="$(IntermediateOutputPath)"
        OmniAssertCoreAssembly="$(OmniAssertCoreAssembly)"
        ProjectDirectory="$(MSBuildProjectDirectory)"
        OmniAssertRewrite="$(OmniAssertRewrite)">
      <Output TaskParameter="RewrittenCompile" ItemName="_OmniAssertRewrittenCompile" />
    </OmniAssertRewriteTask>
    <ItemGroup>
      <Compile Remove="@(Compile)" />
      <Compile Include="@(_OmniAssertRewrittenCompile)" />
    </ItemGroup>
  </Target>
</Project>
